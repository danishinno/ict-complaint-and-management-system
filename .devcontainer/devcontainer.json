{
  "name": "PHP & MySQL (ICMCS)",
  "image": "mcr.microsoft.com/devcontainers/php:8.2",
  "features": {
    "ghcr.io/devcontainers/features/mysql:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [8080, 3306],
  "portsAttributes": {
    "8080": {
      "label": "ICMCS Web Server",
      "onAutoForward": "openPreview"
    },
    "3306": {
      "label": "MySQL Database",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "sudo service mysql start || true; sudo rm -rf /var/www/html || true; sudo ln -sf /workspaces/ict-complaint-and-management-system /var/www/html",
  "customizations": {
    "vscode": {
      "settings": {
        "php.suggest.basic": false
      },
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "mrmlnc.vscode-apache"
      ]
    }
  },
  "remoteUser": "vscode"
}
